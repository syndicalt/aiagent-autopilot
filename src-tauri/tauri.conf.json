{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Autopilot",
  "version": "0.1.0",
  "identifier": "com.autopilot.app",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "frontendDist": "../gui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Autopilot",
        "width": 420,
        "height": 640,
        "resizable": false,
        "fullscreen": false,
        "visible": true,
        "decorations": true,
        "alwaysOnTop": false
      }
    ],
    "trayIcon": {
      "id": "main",
      "iconPath": "icons/32x32.png",

      "tooltip": "Autopilot Agent"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ]
  }
}
